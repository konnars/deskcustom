{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Deskcustom",
  "version": "0.1.1",
  "identifier": "com.deskcustom.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Deskcustom",
        "width": 920,
        "height": 760,
        "minWidth": 720,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": ["nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "languages": ["Russian", "English"],
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    },
    "shortDescription": "Keyboard and mouse sharing",
    "longDescription": "Deskcustom — share keyboard, mouse and clipboard between Windows and Mac over LAN."
  },
  "plugins": {
    "updater": {
      "active": false,
      "dialog": false,
      "endpoints": [],
      "pubkey": ""
    }
  }
}
